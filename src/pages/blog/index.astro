---
import Base from '../../layouts/Base.astro';
import BlogList from '../../components/BlogList.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---

<Base title="Blog - Your Name" description="My thoughts on software development and technology">
  <section>
    <div class="text-text-muted text-sm mb-2">~/blog</div>
    <h1 class="text-accent text-3xl font-bold mb-8">Blog</h1>

    <BlogList posts={posts} />
  </section>
</Base>
