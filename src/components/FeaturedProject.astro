---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const techColorMap: Record<string, string> = {
  'React': 'tag-react',
  'TypeScript': 'tag-typescript',
  'Node.js': 'tag-node',
  'Python': 'tag-python',
  'Go': 'tag-go',
  'Rust': 'tag-rust',
};
---

<div class="project-card glow-accent hover:glow-accent transition-all duration-300 hover:scale-[1.02]">
  <!-- Header -->
  <div class="flex justify-between items-start mb-4">
    <h2 class="text-accent text-xl font-bold">★ {project.title}</h2>
    {project.stars && (
      <span class="text-text-muted text-sm flex items-center gap-1">
        ⭐ {project.stars}
      </span>
    )}
  </div>

  <!-- Description -->
  <p class="text-text-primary mb-4">{project.description}</p>

  <!-- Tech Tags -->
  <div class="flex gap-2 mb-4">
    {project.tech.map((t) => (
      <span class={`tag ${techColorMap[t] || 'tag-react'}`}>{t}</span>
    ))}
  </div>

  <!-- Links -->
  <div class="flex gap-4 text-sm">
    {project.github && (
      <a href={project.github} target="_blank" rel="noopener" class="text-text-muted hover:text-accent transition-colors flex items-center gap-1">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.835 1.305 3.51.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        GitHub
      </a>
    )}
    {project.demo && (
      <a href={project.demo} target="_blank" rel="noopener" class="text-text-muted hover:text-success transition-colors">
        🔗 Demo
      </a>
    )}
    {project.docs && (
      <a href={project.docs} target="_blank" rel="noopener" class="text-text-muted hover:text-highlight transition-colors">
        📄 Docs
      </a>
    )}
  </div>
</div>
