---
import TypingAnimation from './TypingAnimation.astro';
import Particle from './Particle.astro';
---

<section class="relative min-h-[50vh] md:min-h-[60vh] flex flex-col items-start py-8 md:py-16">
  <!-- Floating Particles - hidden on small screens -->
  <div class="hidden sm:block absolute inset-0">
    <Particle color="accent" size="md" position={{ top: '15%', right: '8%' }} delay={0} />
    <Particle color="success" size="sm" position={{ top: '25%', right: '15%' }} delay={0.5} />
    <Particle color="highlight" size="sm" position={{ top: '10%', right: '20%' }} delay={1} />
  </div>

  <!-- Terminal Content -->
  <div class="font-mono w-full max-w-2xl">
    <!-- Directory indicator -->
    <div class="text-text-muted text-xs md:text-sm mb-3 md:mb-4">
      ~/portfolio <span class="text-success">(main)</span>
    </div>

    <!-- Command: whoami -->
    <div class="terminal-command text-base md:text-lg mb-2">
      $ <TypingAnimation text="whoami" delay={300} speed={80} />
    </div>

    <!-- Output - more prominent with line breaks -->
    <div class="terminal-output mt-4 md:mt-6 space-y-2 md:space-y-3">
      <div class="text-highlight text-2xl md:text-3xl font-bold">
        <TypingAnimation text="moonylt" delay={800} speed={60} />
      </div>
      <div class="border-l-2 border-accent pl-4 mt-2">
        <div class="text-text-primary text-base md:text-lg font-semibold">
          <TypingAnimation text="Embedded Developer" delay={1400} speed={50} />
        </div>
        <div class="text-text-primary text-base md:text-lg font-semibold mt-1">
          <TypingAnimation text="Hardware Engineer" delay={1800} speed={50} />
        </div>
      </div>
      <div class="text-text-muted text-sm md:text-base mt-3 max-w-xl">
        <TypingAnimation text="Building hardware solutions for biomedical and other gadgets." delay={2500} speed={30} />
      </div>
    </div>

    <!-- Command: ls projects -->
    <div class="terminal-command text-base md:text-lg mt-8 md:mt-10">
      $ <TypingAnimation text="ls projects/" delay={3500} speed={80} />
    </div>

    <!-- Clickable project links -->
    <div class="flex flex-wrap gap-3 md:gap-4 mt-3 md:mt-4 text-sm md:text-base">
      <a href="/projects/ecg-physio" class="text-accent hover:text-success hover:underline transition-colors">
        <TypingAnimation text="ECG-physio/" delay={4200} speed={50} />
      </a>
      <a href="/projects/video-convertor" class="text-accent hover:text-success hover:underline transition-colors">
        <TypingAnimation text="Video_Covertor/" delay={4500} speed={50} />
      </a>
      <a href="/blog" class="text-accent hover:text-success hover:underline transition-colors">
        <TypingAnimation text="blog/" delay={4800} speed={50} />
      </a>
    </div>

    <!-- Blinking cursor -->
    <div class="terminal-cursor mt-4 md:mt-6 text-accent">█</div>
  </div>

  <!-- Skill tags -->
  <div class="flex flex-wrap gap-2 mt-8 md:mt-12">
    <span class="tag tag-c">C</span>
    <span class="tag tag-verilog">Verilog</span>
    <span class="tag tag-embedded">Embedded</span>
    <span class="tag tag-fpga">FPGA</span>
  </div>

  <!-- CTA -->
  <div class="mt-6 md:mt-8 flex flex-col sm:flex-row gap-3 md:gap-4">
    <a href="/projects" class="bg-accent/20 border border-accent/40 text-accent px-4 py-2 rounded hover:bg-accent/30 transition-colors text-center">
      View Projects →
    </a>
    <a href="/about" class="text-text-muted hover:text-text-primary transition-colors text-center">
      About Me →
    </a>
  </div>
</section>