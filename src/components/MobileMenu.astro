---
interface Props {
  navItems: { name: string; path: string }[];
  currentPath: string;
}

const { navItems, currentPath } = Astro.props;
---

<div class="md:hidden relative">
  <button
    id="menu-toggle"
    aria-label="Toggle menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
    class="text-text-muted hover:text-text-primary p-2"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>

  <div id="mobile-menu" class="hidden absolute right-0 mt-2 bg-bg-secondary border border-border rounded-lg p-4 min-w-[150px]">
    {navItems.map((item) => (
      <a
        href={item.path}
        class={`block py-2 nav-link ${currentPath === item.path ? 'nav-link-active' : ''}`}
      >
        {item.name}
      </a>
    ))}
  </div>
</div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isHidden = menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    toggle?.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
  });

  // Close menu when clicking outside
  document.addEventListener('click', (e) => {
    const target = e.target;
    if (target instanceof Node && !toggle?.contains(target) && !menu?.contains(target)) {
      menu?.classList.add('hidden');
    }
  });

  // Close menu when pressing Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.focus();
    }
  });
</script>
