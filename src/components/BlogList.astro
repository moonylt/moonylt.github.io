---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;

// Sort by date descending
const sortedPosts = posts.sort((a, b) =>
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<div class="space-y-4">
  {sortedPosts.map((post) => {
    const date = new Date(post.data.pubDate);
    const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });

    return (
      <a
        href={`/blog/${post.id}`}
        class="flex justify-between items-center py-3 border-b border-border/50 hover:border-accent/50 transition-colors group"
      >
        <span class="text-accent group-hover:text-success transition-colors">{post.data.title}</span>
        <span class="text-text-muted text-sm">{dateStr}</span>
      </a>
    );
  })}
</div>
