---
import type { Project } from '../data/projects';
import { techColorMap } from '../data/techColors';

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div class="mt-8">
  <h3 class="text-text-muted text-sm mb-4">Other Projects</h3>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {projects.map((project) => (
      <a
        href={`/projects/${project.slug}`}
        class="project-card flex justify-between items-center group"
      >
        <div>
          <span class="text-accent group-hover:text-success transition-colors">{project.title}/</span>
          <div class="flex gap-2 mt-2">
            {project.tech.slice(0, 2).map((t) => (
              <span class={`tag ${techColorMap[t] || ''} text-xs`}>{t}</span>
            ))}
          </div>
        </div>
        <div class="flex items-center gap-2">
          {project.stars && (
            <span class="text-text-muted text-sm">⭐ {project.stars}</span>
          )}
          <span class="text-text-muted text-sm group-hover:text-success transition-colors">→</span>
        </div>
      </a>
    ))}
  </div>
</div>