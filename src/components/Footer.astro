---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border py-6 mt-auto">
  <div class="max-w-6xl mx-auto px-4 md:px-8 lg:px-16 flex flex-col md:flex-row justify-between items-center gap-4">
    <div class="text-text-muted text-sm">
      © {currentYear} moonylt. Built with Astro.
    </div>
    <div class="flex gap-4">
      <a href="https://github.com/yourname" target="_blank" rel="noopener" class="text-text-muted hover:text-accent transition-colors">
        GitHub
      </a>
      <a href="https://linkedin.com/in/yourname" target="_blank" rel="noopener" class="text-text-muted hover:text-accent transition-colors">
        LinkedIn
      </a>
      <a href="mailto:your@email.com" class="text-text-muted hover:text-accent transition-colors">
        Email
      </a>
    </div>
  </div>
</footer>
